{
    "version": 3,

    "configurePresets": [
        {
            "name": "win64",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build64",
            "cacheVariables": {
                "TARGET_ARCH": "x64"
            }
        },

        {
            "name": "win32",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build32",
            "cacheVariables": {
                "TARGET_ARCH": "x86"
            }
        },

        {
            "name": "linux64",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-linux64",
            "cacheVariables": {
                "TARGET_ARCH": "x64"
            }
        },

        {
            "name": "linux32",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-linux32",
            "cacheVariables": {
                "TARGET_ARCH": "x86"
            }
        }
    ],

    "buildPresets": [
        {
            "name": "build-win64",
            "configurePreset": "win64"
        },

        {
            "name": "build-win32",
            "configurePreset": "win32"
        },

        {
            "name": "build-linux64",
            "configurePreset": "linux64"
        },

        {
            "name": "build-linux32",
            "configurePreset": "linux32"
        }
    ]
}
